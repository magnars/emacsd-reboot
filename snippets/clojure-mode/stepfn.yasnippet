# -*- mode: snippet -*-
# name: clojure.core.async.flow step fn
# key: stepfn
# --
(defn step
  ([] {})
  ([argmap] {})
  ([state transition]
   (case transition
     :clojure.core.async.flow/resume state
     :clojure.core.async.flow/pause state
     :clojure.core.async.flow/stop state))
  ([state input msg] [state nil]))
